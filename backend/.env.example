PORT=5000
DB_PORT=3306
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=hotel_booking_db
# DB_SSL=true                  # Uncomment to require secure managed cloud database connections
# DB_SSL_CA_BASE64=            # Provide CA certificate as a Base64-encoded string if required by the cloud provider
JWT_SECRET=replace_with_a_private_random_secret_of_at_least_32_characters
JWT_EXPIRES_IN=7d

# TRUST_PROXY: Configures Express "trust proxy" setting.
# - false (default): Use for direct connections or local development.
# - 1: Use when exactly one trusted reverse proxy (e.g. Render, NGINX) is in front.
# Production value must match the deployment topology.
TRUST_PROXY=false
CLIENT_URL=http://localhost:5173
APP_TIMEZONE=Asia/Colombo
